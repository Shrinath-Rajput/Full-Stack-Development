                        <p>Experience blazing fast performance with our optimized platform built for speed and efficiency.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h4>Highly Secure</h4>
                        <p>Enterprise-grade security with encryption and compliance standards to protect your data.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-headset"></i>
                        </div>
                        <h4>24/7 Support</h4>
                        <p>Our dedicated support team is always ready to help you succeed with our platform.</p>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h4>Real-time Analytics</h4>
                        <p>Track your progress with detailed analytics and comprehensive reporting tools.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                        <h4>Responsive Design</h4>
                        <p>Works perfectly on all devices - desktop, tablet, and mobile platforms.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-plug"></i>
                        </div>
                        <h4>Easy Integration</h4>
                        <p>Integrate with your favorite tools and services seamlessly and quickly.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section with Total Users -->
    <section class="stats-section">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 id="totalUsers"><%= result %></h3>
                        <p>Total Users</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3>150+</h3>
                        <p>Countries</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3>99.9%</h3>
                        <p>Uptime</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3>1M+</h3>
                        <p>Data Points</p>
                    </div>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <button id="refreshBtn" class="btn btn-light btn-lg" onclick="refreshUserCount()">
                        <i class="fas fa-sync-alt"></i> Refresh User Count
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section" id="contact">
        <div class="container">
            <h2>Ready to Get Started?</h2>
            <p>Join thousands of satisfied customers who trust ProApp</p>
            <form class="row justify-content-center g-3" style="max-width: 500px; margin: 0 auto;">
                <div class="col-12">
                    <input type="email" class="form-control form-control-lg" placeholder="Enter your email" required>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary-custom w-100">Sign Up Now</button>
                </div>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer id="about">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <h5>About Us</h5>
                    <p>ProApp is a leading platform for building professional applications with cutting-edge technology.</p>
                    <div class="social-links">
                        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" title="GitHub"><i class="fab fa-github"></i></a>
                    </div>
                </div>
                <div class="col-md-3">
                    <h5>Product</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Features</a></li>
                        <li><a href="#">Pricing</a></li>
                        <li><a href="#">Security</a></li>
                        <li><a href="#">Roadmap</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Company</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">About</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Legal</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Cookie Policy</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 ProApp. All rights reserved. | Built with <i class="fas fa-heart" style="color: var(--accent-color);"></i> by Your Team</p>
            </div>
        </div>
    </footer>

    <div class="div5">
        <h2>The total No of Users :</h2>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Function to refresh user count
        function refreshUserCount() {
            const btn = document.getElementById('refreshBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';

            fetch('/')
                .then(response => response.text())
                .then(html => {
                    // Parse the HTML to extract the user count
                    const parser = new DOMParser();
                    const newDoc = parser.parseFromString(html, 'text/html');
                    const newCount = newDoc.getElementById('totalUsers').textContent;
                    
                    // Update the count with animation
                    const userElement = document.getElementById('totalUsers');
                    userElement.style.transition = 'all 0.6s ease';
                    userElement.style.transform = 'scale(1.2)';
                    userElement.style.color = '#e74c3c';
                    
                    setTimeout(() => {
                        userElement.textContent = newCount;
                        userElement.style.transform = 'scale(1)';
                        userElement.style.color = 'white';
                    }, 300);

                    // Reset button
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-sync-alt"></i> Refresh User Count';
                    
                    // Show success message
                    showAlert('✅ User count updated!', 'success');
                })
                .catch(error => {
                    console.error('Error:', error);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-sync-alt"></i> Refresh User Count';
                    showAlert('❌ Failed to refresh user count', 'danger');
                });
        }

        // Alert function
        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            alertDiv.style.top = '20px';
            alertDiv.style.right = '20px';
            alertDiv.style.zIndex = '9999';
            alertDiv.style.minWidth = '300px';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                alertDiv.remove();
            }, 3000);
        }
    </script>
</body>
</html>